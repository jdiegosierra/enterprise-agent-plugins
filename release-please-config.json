        {
          "type": "json",
          "path": "claude/.claude-plugin/plugin.json",
          "jsonpath": "$.version"
        }
      ]
    },
    "plugins/acme-marketing": {
      "component": "acme-marketing",
      "extra-files": [
        {
          "type": "json",
          "path": "claude/.claude-plugin/plugin.json",
